<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".appenterlogin.CreateNewAccountActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/mainCV"
        app:cardElevation="12dp"
        android:background="@color/white"
        app:cardCornerRadius="25dp"
        android:padding="33dp"
        android:layout_marginHorizontal="18dp"
        android:outlineSpotShadowColor="@color/black"
        android:outlineAmbientShadowColor="@color/black"
        android:layout_marginBottom="60dp"
        android:layout_width="match_parent"
        android:layout_height="433dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/email_TV"
                android:textColor="@color/black"
                android:textSize="14dp"
                android:layout_marginTop="22dp"
                android:layout_marginStart="22dp"
                android:text="Email"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:inputType="textEmailAddress"
                android:id="@+id/email_ET"
                android:textSize="14dp"
                android:paddingStart="11dp"
                android:hint="Enter email"
                android:background="@drawable/input_bg"
                android:layout_marginTop="5dp"
                android:layout_marginHorizontal="22dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/email_TV"
                android:layout_width="match_parent"
                android:layout_height="33dp"/>

            <TextView
                android:id="@+id/password_TV"
                android:textColor="@color/black"
                android:textSize="14dp"
                android:layout_marginTop="15dp"
                android:layout_marginStart="22dp"
                android:text="Password"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/email_ET"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:inputType="textPassword"
                android:id="@+id/password_ET"
                android:textSize="14dp"
                android:paddingStart="11dp"
                android:hint="Enter password"
                android:background="@drawable/input_bg"
                android:layout_marginTop="5dp"
                android:layout_marginHorizontal="22dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/password_TV"
                android:layout_width="match_parent"
                android:layout_height="33dp"/>






            <Button
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:text="Sign Up"
                android:gravity="center"
                android:id="@+id/SignBT"
                android:textSize="14dp"
                android:background="@drawable/loginbotton_bg"
                android:layout_marginTop="22dp"
                android:layout_marginHorizontal="22dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Cpassword_ET"
                android:layout_width="match_parent"
                android:layout_height="33dp"/>

            <View
                android:id="@+id/v"
                android:layout_marginHorizontal="22dp"
                android:background="#65000000"
                android:layout_marginTop="22dp"
                app:layout_constraintTop_toBottomOf="@id/SignBT"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>

            <TextView
                android:background="@color/white"
                app:layout_constraintStart_toStartOf="@id/v"
                app:layout_constraintEnd_toEndOf="@id/v"
                app:layout_constraintBottom_toBottomOf="@id/v"
                app:layout_constraintTop_toTopOf="@id/v"
                android:text="or"
                android:gravity="center"
                android:layout_width="23dp"
                android:layout_height="23dp"/>

            <Button
                android:textAllCaps="false"
                android:id="@+id/googleSign_BT"
                android:textSize="14dp"
                android:paddingStart="11dp"
                android:text="Sign Up with Google"
                android:background="@drawable/input_bg"
                android:layout_marginTop="22dp"
                android:layout_marginHorizontal="22dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/v"
                android:layout_width="match_parent"
                android:layout_height="33dp"/>

            <ImageView
                android:src="@drawable/google"
                android:layout_marginStart="40dp"
                app:layout_constraintStart_toStartOf="@id/googleSign_BT"
                app:layout_constraintBottom_toBottomOf="@id/googleSign_BT"
                app:layout_constraintTop_toTopOf="@id/googleSign_BT"
                android:layout_width="16dp"
                android:layout_height="16dp"/>


            <TextView
                app:layout_constraintEnd_toStartOf="@id/log_BT"
                android:paddingStart="24dp"
                android:id="@+id/reg_TV"
                android:textColor="@color/black"
                android:textSize="12dp"
                android:layout_marginTop="22dp"
                android:layout_marginStart="22dp"
                android:text="Already have an account?"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/googleSign_BT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/reg_TV"
                android:id="@+id/log_BT"
                android:textColor="#0C30F8"
                android:textSize="11dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="22dp"
                android:text="Login here"
                android:paddingEnd="18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/googleSign_BT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/Cpassword_TV"
                android:textColor="@color/black"
                android:textSize="14dp"
                android:layout_marginTop="15dp"
                android:layout_marginStart="22dp"
                android:text="Confirm Password"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/password_ET"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:inputType="textPassword"
                android:id="@+id/Cpassword_ET"
                android:textSize="14dp"
                android:paddingStart="11dp"
                android:hint="Confirm password"
                android:background="@drawable/input_bg"
                android:layout_marginTop="5dp"
                android:layout_marginHorizontal="22dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/Cpassword_TV"
                android:layout_width="match_parent"
                android:layout_height="33dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <ImageView
        android:id="@+id/EV"
        android:layout_marginBottom="10dp"
        android:elevation="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/mobileapplogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/mainCV"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="115dp"
        android:layout_height="115dp"/>

    <TextView
        app:layout_constraintBottom_toTopOf="@id/appnameV"
        android:id="@+id/welcomV"
        android:textSize="17dp"
        android:text="Welcome to"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/EV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        app:layout_constraintBottom_toTopOf="@id/CV"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:id="@+id/appnameV"
        android:textSize="18dp"
        android:text="UA Shoping Center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/welcomV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        app:layout_constraintBottom_toTopOf="@id/mainCV"
        android:id="@+id/CV"
        android:textSize="13dp"
        android:text="Create your account"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appnameV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>



</androidx.constraintlayout.widget.ConstraintLayout>