<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.SellerActivity">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>


    <LinearLayout
        android:paddingTop="13dp"
        android:paddingBottom="5dp"
        android:backgroundTint="#FFFFFF"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/tabLayout1"
        android:background="#FFFFFF"
        android:gravity="top"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <ImageView
            android:id="@+id/dashboardBT"
            android:src="@drawable/ic_home_white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="37dp"/>
        <ImageView
            android:id="@+id/productsBT"
            android:src="@drawable/ic_category_white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="37dp"/>
        <ImageView
            android:id="@+id/ordersBT"
            android:src="@drawable/ic_cart_white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="37dp"
            />
        <ImageView
            android:id="@+id/earningsBT"
            android:src="@drawable/ic_profile_white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="37dp" />
        <ImageView
            android:id="@+id/moreBT"
            android:src="@drawable/ic_profile_white"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="37dp" />
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:animateLayoutChanges="false"
        app:tabIndicatorColor="#00FF6B00"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="match_parent"
        android:layout_height="60dp"/>





</androidx.constraintlayout.widget.ConstraintLayout>