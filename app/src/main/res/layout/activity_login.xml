<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".appenterlogin.LoginActivity">

    <LinearLayout
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/EV"
            android:layout_width="115dp"
            android:layout_height="115dp"
            android:layout_marginBottom="10dp"
            android:elevation="14dp"
            android:src="@drawable/image_app_logo" />

        <TextView
        android:textStyle="bold"
        android:textColor="@color/black"
        android:id="@+id/appnameV"
        android:textSize="18dp"
        android:text="UA Shoping Center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

        <TextView
        android:id="@+id/CV"
        android:textSize="13dp"
        android:text="Login your account"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCV"
            android:layout_marginTop="15dp"
            app:cardElevation="3dp"
            android:background="@color/white"
            app:cardCornerRadius="25dp"
            android:layout_marginHorizontal="18dp"
            android:outlineSpotShadowColor="@color/black"
            android:outlineAmbientShadowColor="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:paddingVertical="20dp"
                android:layout_height="match_parent">
                <TextView
                    android:id="@+id/email_TV"
                    android:textColor="@color/black"
                    android:textSize="14dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="22dp"
                    android:text="Email"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:inputType="textEmailAddress"
                    android:id="@+id/email_ET"
                    android:textSize="14dp"
                    android:paddingStart="11dp"
                    android:hint="Enter your email"
                    android:background="@drawable/input_bg"
                    android:layout_marginTop="5dp"
                    android:layout_marginHorizontal="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/email_TV"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"/>

                <TextView
                    android:id="@+id/password_TV"
                    android:textColor="@color/black"
                    android:textSize="14dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginStart="22dp"
                    android:text="Password"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/email_ET"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:inputType="textPassword"
                    android:id="@+id/password_ET"
                    android:textSize="14dp"
                    android:paddingStart="11dp"
                    android:hint="Enter password"
                    android:background="@drawable/input_bg"
                    android:layout_marginTop="5dp"
                    android:layout_marginHorizontal="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/password_TV"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"/>


                <TextView
                    android:paddingStart="24dp"
                    android:id="@+id/remanderme_TV"
                    android:textColor="@color/black"
                    android:textSize="12dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginStart="22dp"
                    android:text="Rememder me"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/password_ET"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <CheckBox
                    android:backgroundTint="#E70B2CE6"
                    android:layout_marginStart="13dp"
                    app:layout_constraintBottom_toBottomOf="@id/remanderme_TV"
                    app:layout_constraintTop_toTopOf="@id/remanderme_TV"
                    app:layout_constraintStart_toStartOf="parent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>


                <TextView

                    android:id="@+id/fargatP_TV"
                    android:textColor="#0C30F8"
                    android:textSize="11dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="22dp"
                    android:text="Forgot Password?"

                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/password_ET"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:text="Login"
                    android:gravity="center"
                    android:id="@+id/loginBT"
                    android:textSize="14dp"
                    android:background="@drawable/loginbotton_bg"
                    android:layout_marginTop="22dp"
                    android:layout_marginHorizontal="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/remanderme_TV"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"/>

                <View
                    android:id="@+id/v"
                    android:layout_marginHorizontal="22dp"
                    android:background="#65000000"
                    android:layout_marginTop="22dp"
                    app:layout_constraintTop_toBottomOf="@id/loginBT"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"/>

                <TextView
                    android:background="@color/white"
                    app:layout_constraintStart_toStartOf="@id/v"
                    app:layout_constraintEnd_toEndOf="@id/v"
                    app:layout_constraintBottom_toBottomOf="@id/v"
                    app:layout_constraintTop_toTopOf="@id/v"
                    android:text="or"
                    android:gravity="center"
                    android:layout_width="23dp"
                    android:layout_height="23dp"/>

                <Button
                    android:textAllCaps="false"
                    android:id="@+id/googlelogin_BT"
                    android:textSize="14dp"
                    android:paddingStart="11dp"
                    android:text="Login with Google"
                    android:background="@drawable/input_bg"
                    android:layout_marginTop="22dp"
                    android:layout_marginHorizontal="22dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/v"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"/>

                <ImageView
                    android:src="@drawable/google"
                    android:layout_marginStart="40dp"
                    app:layout_constraintStart_toStartOf="@id/googlelogin_BT"
                    app:layout_constraintBottom_toBottomOf="@id/googlelogin_BT"
                    app:layout_constraintTop_toTopOf="@id/googlelogin_BT"
                    android:layout_width="16dp"
                    android:layout_height="16dp"/>


                <TextView
                    app:layout_constraintEnd_toStartOf="@id/reg_BT"
                    android:paddingStart="24dp"
                    android:id="@+id/reg_TV"
                    android:textColor="@color/black"
                    android:textSize="12dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginStart="22dp"
                    android:text="Don't have an account?"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/googlelogin_BT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@id/reg_TV"
                    android:id="@+id/reg_BT"
                    android:textColor="#0C30F8"
                    android:textSize="11dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginEnd="22dp"
                    android:text="Register Now"
                    android:paddingEnd="18dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/googlelogin_BT"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>




</androidx.constraintlayout.widget.ConstraintLayout>