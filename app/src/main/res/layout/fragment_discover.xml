<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/app_background_gradient"
    android:layout_height="match_parent"
    android:paddingHorizontal="5dp"
    tools:context=".Fragments.DiscoverFragment">
    <ScrollView
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">



    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="45dp"
            android:gravity="bottom"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_app_icon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginBottom="2dp"
                android:text="Shopping Center"
                android:textColor="@color/white"
                android:textSize="20dp"
                android:textStyle="bold" />

        </LinearLayout>





    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/line1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#A6A4A4"
        app:layout_constraintTop_toBottomOf="@id/topBar" />


    <androidx.cardview.widget.CardView
        android:id="@+id/search_cardView"
        app:cardCornerRadius="25dp"
        app:layout_constraintTop_toBottomOf="@id/line1"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginHorizontal="2dp"
        android:layout_width="match_parent"
        app:cardUseCompatPadding="true"
        android:elevation="6dp"
        android:layout_height="wrap_content">


        <EditText
            android:id="@+id/seach_bar"
            app:layout_constraintTop_toBottomOf="@id/line1"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:visibility="visible"
            android:maxLines="1"
            android:textSize="16dp"
            android:paddingStart="40dp"
            android:textColor="@color/white"
            android:textColorHint="@color/white"
            android:hint="Search Product, category and item"
            android:background="@drawable/bg_search"
            android:layout_height="35dp"/>
        <ImageView
            android:layout_marginStart="5dp"
            android:layout_marginVertical="5dp"
            android:padding="5dp"
            app:tint="@color/white"
            android:src="@drawable/ic_search"
            android:layout_marginBottom="5dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="25dp"
            android:layout_height="25dp"/>

    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/item_show_recyclerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/search_cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>


        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>