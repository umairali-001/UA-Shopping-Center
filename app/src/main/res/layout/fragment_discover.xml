                    android:textColor="#111111"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:maxLines="2" />
                </LinearLayout>
            </FrameLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:paddingHorizontal="8dp"
