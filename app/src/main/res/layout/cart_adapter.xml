<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#FFFFFF">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Checkbox Toggle -->
        <CheckBox
            android:id="@+id/cb_select_product"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:checked="true"
            android:buttonTint="#00A36C"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Product Image Showcase -->
        <ImageView
            android:id="@+id/iv_cart_product"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/images_8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/cb_select_product"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Info Description Block -->
        <LinearLayout
            android:id="@+id/ll_info_block"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/iv_cart_product"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_product_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="boAt Wave Smart Watch"
                android:textColor="#111111"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_product_variant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Black"
                android:textColor="#666666"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_curr_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹1,499"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_old_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="₹2,899"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:background="@drawable/strike_line" />

                <TextView
                    android:id="@+id/tv_discount_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="50% OFF"
                    android:textColor="#00A36C"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Product Action Counter Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_counter_box"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/ll_info_block"
            app:layout_constraintTop_toBottomOf="@id/ll_info_block">

            <ImageView
                android:id="@+id/btn_minus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:src="@drawable/ic_minus"
                app:tint="#333333" />

            <TextView
                android:id="@+id/tv_qty_count"
                android:layout_width="32dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="1"
                android:textColor="#111111"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_plus"
                android:layout_width="28dp"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:src="@drawable/ic_plus"
                app:tint="#333333" />
        </LinearLayout>

        <!-- Trash Delete Trigger Button -->
        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_trash"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#AD000000" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>