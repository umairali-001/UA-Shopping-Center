<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_margin="5dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="10dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        app:cardBackgroundColor="#E2E3E7"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_margin="0dp"
                        app:cardCornerRadius="7dp">

                        <ImageView
                            android:id="@+id/item_image_adapter"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/image_1" />

                    </androidx.cardview.widget.CardView>

                    <TextView

                        android:id="@+id/item_name_adapter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="4dp"
                        android:text="this is one of the best thing in this world "
                        android:textColor="#000000"
                        android:textSize="14.5sp" />

                    <LinearLayout
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textColor="@color/primaryGreenColor"
                            android:textSize="15dp"
                            android:text="Rs."
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView
                            android:textStyle="bold"
                            android:id="@+id/item_price_adapter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12,300"
                            android:textColor="@color/primaryGreenColor"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/off_TV"
                            android:textStyle="bold"
                            android:text="10000"
                            android:textColor="#8D9793"
                            android:textSize="16sp"
                            android:layout_marginStart="10dp"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>


                    <TextView
                        android:textStyle="bold"
                        android:id="@+id/item_ratting_adapter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="14dp"
                        android:layout_marginTop="6dp"
                        android:text="4.5"
                        android:layout_marginBottom="10dp"
                        android:textColor="@color/black"
                        android:textSize="13sp" />


                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>